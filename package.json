{
  "name": "dench-fetch",
  "version": "0.1.0-beta.7",
  "description": "A lightweight and efficient HTTP client library for modern JavaScript environments, built on top of the Fetch API.",
  "homepage": "https://github.com/luckydeench/dench#readme",
  "bugs": {
    "url": "https://github.com/luckydeench/dench/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luckydeench/dench.git"
  },
  "license": "MIT",
  "author": "etanolfly98 <etanolfly98@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:no-vitest": "tsx src/test.ts",
    "test:log": "tsx --tsconfig devtools/tsconfig.json devtools/test_log.ts",
    "codex:docs": "tsx --tsconfig devtools/tsconfig.json devtools/codex_docs_check.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "build:log": "tsx --tsconfig devtools/tsconfig.json devtools/build_log.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build:log",
    "publish:beta": "npm publish --tag beta",
    "version:beta": "npm version prerelease --preid=beta",
    "version:view": "npm view dench-fetch versions",
    "postinstall":  "echo npm install 이후 실행됨",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
