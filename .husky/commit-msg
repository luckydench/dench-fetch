if grep -E "^(feat|fix|docs|test|config|hotfix|dependency|settings|refactor)" "$1"; then
        echo "Commit message format is correct."
    else
        echo "Error: Commit message format is incorrect."
        echo "Please use the format: <type> : <description>"
        echo "Where <type> is one of feat, fix, docs, test, config, hotfix, dependency, settings, refactor."
        exit 1
    fi